<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:style="clr-namespace:Content.Client.Stylesheets"
    xmlns:tabs="clr-namespace:Content.Client._Gabystation.ServerCurrency.UI"
    VerticalExpand="True" HorizontalExpand="True"
    Title="{Loc gs-balanceui-title}"
    SetSize="670 580" >
    <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
        <controls:StripeBack>
            <PanelContainer>
                <Label Name="Header" Text=" " StyleClasses="LabelHeading"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10 10 10 10" ReservesSpace="False"/>
            </PanelContainer>
        </controls:StripeBack>

        <BoxContainer Orientation="Horizontal"> <!-- Should exist a better way to separate into two panels-->

            <BoxContainer Name="LeftSide" Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
                <!-- Store -->

                <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
                    <TabContainer Name="Tabs">
                        <!-- Tokens -->
                        <tabs:TokenStoreTab Name="TokenStore" Access="Public"/>
                        <!-- titles -->
                        <tabs:TitleStoreTab Name="TitleStore" Access="Public"/>
                        <!-- ghots -->
                        <tabs:GhostStoreTab Name="GhostStore" Access="Public"/>
                    </TabContainer>
                    <Label Name="ConfirmationMessage" Text="" HorizontalAlignment="Center"/>
                    <Label Text="{Loc gs-balanceui-shop-footer}" />
                </BoxContainer>
                <!--  -->
            </BoxContainer>

            <BoxContainer Name="RightSide" Orientation="Vertical" Margin="15 0 15 15">
                <Label Text="{Loc gs-balanceui-select-title}" />
                <OptionButton Name="SelectTitle" Access="Public" HorizontalExpand="True" />
                <RichTextLabel Name="TitlePreview" />

                <controls:HSpacer Spacing="5" />

                <Label Text="{Loc gs-balanceui-select-ghost}" />
                <OptionButton Name="SelectGhost" Access="Public" HorizontalExpand="True" />

                <controls:HSpacer Spacing="15" />
                <controls:HLine Color="#FFFFFF" Thickness="2" Margin="0 5 0 5"/>
                <controls:HSpacer Spacing="15" />

                <!-- Gift -->
                <Label Text="{Loc gs-balanceui-gift-label}" />
                <BoxContainer>
                    <LineEdit Name="GiftPlayer" PlaceHolder="{Loc gs-balanceui-gift-player}" ToolTip="{Loc gs-balanceui-gift-player-tooltip}" MinWidth="170" />
                    <LineEdit Name="GiftAmmount" PlaceHolder="{Loc gs-balanceui-gift-value}" ToolTip="{Loc gs-balanceui-gift-value-tooltip}" HorizontalExpand="True" MinWidth="50" />
                </BoxContainer>
                <Button Name="GiftButton" Text="{Loc gs-balanceui-confirm}" StyleClasses="ButtonColorGaby" />

                <BoxContainer VerticalExpand="True" />

                <!-- Admin Panel -->
                <BoxContainer Name="Admin" Visible="True" Orientation="Vertical">
                    <Label Text="Admin:" StyleClasses="LabelHeading" />
                    <Label Text="{Loc gs-balanceui-admin-add-label}" />
                    <BoxContainer>
                        <LineEdit Name="AdminAddPlayer" PlaceHolder="{Loc gs-balanceui-admin-add-player}" MinWidth="170" />
                        <LineEdit Name="AdminAddAmmount" PlaceHolder="{Loc gs-balanceui-admin-add-value}" HorizontalExpand="True" MinWidth="50" />
                    </BoxContainer>
                    <Button Name="AdminAddButton" Text="{Loc gs-balanceui-confirm}" StyleClasses="ButtonColorGaby" />
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
