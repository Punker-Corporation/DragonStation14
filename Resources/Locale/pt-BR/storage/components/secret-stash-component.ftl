comp-secret-stash-verb-insert-into-stash = Esconder item
comp-secret-stash-verb-insert-message-item-already-inside = Já tem um item dentro { PREPOSICAO-DE($stashname) } { $stashname }.
comp-secret-stash-verb-insert-message-no-item = Esconder { ARTIGO-O($item) } { $item } { PREPOSICAO-DE($stashname) } { $stashname }.
comp-secret-stash-verb-take-out-item = Pegar item
comp-secret-stash-verb-take-out-message-something = Você pega o conteúdo { PREPOSICAO-DE($stashname) } { $stashname }.
comp-secret-stash-verb-take-out-message-nothing = Não tem nada dentro { PREPOSICAO-DE($stashname) } { $stashname }.

comp-secret-stash-verb-close = Fechar
comp-secret-stash-verb-cant-close = Você não pode fechar { ARTIGO-O($stashname) } { $stashname } com isso.
comp-secret-stash-verb-open = Abrir

