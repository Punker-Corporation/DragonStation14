### Secret stash component. Stuff like potted plants, comfy chair cushions, etc...

comp-secret-stash-action-hide-success = Você esconde { ARTIGO-O($item) } { PREPOSICAO-DE($stashname) } { $stashname }
comp-secret-stash-action-hide-container-not-empty = Já tem algo aqui?!
comp-secret-stash-action-hide-item-too-big = { CAPITALIZE(ARTIGO-O($item)) } é grande demais para caber { PREPOSICAO-DE($stashname) } { $stashname }!
comp-secret-stash-action-get-item-found-something = Tinha alguma coisa dentro { PREPOSICAO-DE($stashname) } {$stashname}!
comp-secret-stash-on-examine-found-hidden-item = Tem alguma coisa escondida dentro { PREPOSICAO-DE($stashname) } { $stashname }!
comp-secret-stash-on-destroyed-popup = Alguma coisa cai de dentro { PREPOSICAO-DE($stashname) } { $stashname }!

