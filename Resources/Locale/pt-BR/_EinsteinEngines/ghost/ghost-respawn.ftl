ghost-respawn-minutes-left = Por favor, aguarde {$time} {$time ->
    [one] minuto
   *[other] minutos
} antes de tentar renascer.
ghost-respawn-seconds-left = Por favor, aguarde {$time} {$time ->
    [one] segundo
   *[other] segundos
} antes de tentar renascer.

ghost-respawn-max-players = Não é possível renascer agora. Deve haver menos de {$players} jogadores.
ghost-respawn-window-title = Regras de Renascimento
ghost-respawn-window-rules-footer = Ao renascer, você [color=#ff7700]concorda[/color][color=#ff0000] em não usar qualquer conhecimento obtido como seu personagem anterior[/color]. A violação desta regra pode resultar em banimento do servidor. Por favor, leia as regras do servidor para mais detalhes.
ghost-respawn-same-character = Você não pode renascer como o mesmo personagem. Por favor, selecione um diferente nas preferências de personagem.

ghost-respawn-log-character-almost-same = Jogador {$player} { $try ->
    [true] entrou
    *[false] tentou entrar
} na rodada após renascer com um nome similar. Nome anterior: { $oldName }, atual: { $newName }.
ghost-respawn-log-return-to-lobby = { $userName } voltou para o lobby.
