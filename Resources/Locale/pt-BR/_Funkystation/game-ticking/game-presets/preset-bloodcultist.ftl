roles-antag-cult-name = Cultista do Sangue
roles-antag-cult-objective = Seu objetivo é invocar seu mestre, o Geômetra do Sangue, Nar'Sie. Por meio da conversão, dominação e sangue, que Ele possa retornar a este mundo. Coopere com seus companheiros Cultistas para rasgar o véu e trazê-lo de volta!

cult-role-greeting =
    Você é um Cultista do Sangue.
    Sua missão é invocar seu mestre, Nar'Sie, para este plano de existência.
    Sacrifique aqueles que a Geômetra do Sangue exige e converta seus colegas de tripulação para rasgar o véu.
    TOK-LYR RQA-NAP G'OLT-ULOFT!!

cult-briefing = Ajude seus companheiros cultistas a converter a tripulação e sacrificar os alvos para invocar sua divindade.

cult-start-briefing = A Geômetra do Sangue tem uma tarefa para você.

cult-briefing-targets = Nar'Sie exige sangue. Inspecione o véu para compreender seus desejos.

admin-verb-make-cultist = Transformar o alvo em um Cultista do Sangue.

cult-dagger-equip-fail = A adaga se transforma em cinzas em suas mãos!

cult-attack-repelled = Magia sagrada repele seu ataque!
cult-attack-teamhit = Seu ataque para antes de atingir um cultista.

contraband-examine-text-BloodCult = [color=crimson]Este item é um produto altamente ilegal da magia cultista do sangue![/color]

cult-rune-drawing-novowel = Você começa a manchar uma runa no chão com o sangue do seu próprio pulso...
cult-rune-drawing-vowel-first = Você começa a manchar um(a)
cult-rune-drawing-vowel-second = no chão com o sangue do seu próprio pulso...
cult-rune-select = Selecionar Runa

cult-veil-drawing-toostrong = O véu está forte demais aqui para ser rasgado.
cult-veil-drawing-pleaseconfirm = Use a adaga novamente para confirmar a área {$name} -- cuidado, a tripulação será alertada!
cult-veil-drawing-wronglocation = Você deve desenhar esta runa na área {$name}!
cult-veil-drawing-alreadyexists = Alguém já desenhou uma runa de rasgar o véu!
cult-veil-drawing-crewwarning = Fragmentos de uma divindade eldritch estão sendo invocados na área {$name} vindos de uma dimensão desconhecida. Interrompa este ritual a todo custo antes que a estação seja destruída. A Lei Espacial e o POP estão suspensos. Toda a tripulação deve matar cultistas ao avistá-los.

cult-invocation-blood-drain = Você sente suas veias estreitarem enquanto seu sangue drena!
cult-invocation-revive-fail = Nar'Sie exige mais sacrifícios!
cult-invocation-fail-nosoul = Nar'Sie rejeita este casulo sem alma!
cult-invocation-fail-teamkill = Nar'Sie rejeita sua oferenda de outro Cultista!
cult-invocation-fail-mindshielded = Sua vítima resiste à influência de Nar'Sie!
cult-invocation-fail-resisted = Esta entidade sagrada resiste à influência de Nar'Sie!
cult-invocation-fail = Mais cultistas devem estar presentes!
cult-invocation-target-fail = Mais cultistas devem estar presentes para sacrificar um que Nar'Sie deseja!
cult-invocation-narsie-fail = Pelo menos nove cultistas devem estar sobre a runa, distribuídos uniformemente, para rasgar o véu.

cult-invocation-barrier = Khari'd! Eske'te tannin!
cult-invocation-revive = Pasnar val'keriam usinar. Savrae ines amutan. Yam'toth remium il'tarat!
cult-invocation-offering = Mah'weyh pleggh at e'ntrath!
cult-invocation-empowering = H'drak v'loso, mir'kanas verbot!

cult-spell-carving = Tentáculos de outro mundo começam a entalhar brutalmente um sigilo em sua carne.
cult-spell-carving-rune = Fortalecido pela runa, você mal sente o sigilo sendo entalhado em sua carne.
cult-spell-exceeded = Você não pode entalhar outro feitiço!
cult-spell-havealready = Você já possui esse feitiço!
cult-spell-fail = Você falha ao conjurar o feitiço!
cult-spell-repelled = Magia sagrada protege seu alvo!

cult-shade-summoned = A alma roubada se materializa como um servo Sombra!
cult-shade-recalled = Você recaptura a alma roubada, revigorando-a!
cult-shade-servant = Você foi libertado de sua prisão, mas ainda está vinculado à vontade de {$name}. Ajude-o a cumprir seus objetivos a todo custo.

cult-soulstone-empty = Você não consegue contatar nenhuma alma desta pedra -- talvez ela esteja vazia.

cult-status-veil-strong = [italic]O Véu precisa ser enfraquecido antes que possamos invocar a Escura.[/italic]

cult-status-veil-weak = [italic]Você e seus acólitos conseguiram preparar a estação para o ritual final![/italic]
cult-veil-torn = O véu... está... rasgado!

cult-status-veil-strong-goal = [italic]Objetivo atual: Sacrificar {$targetName}, o(a) {$targetJob}, invocando uma runa de oferenda com seu corpo ou cérebro sobre ela e pelo menos {$cultistsRequired} cultistas ao redor.[/italic]

cult-status-veil-weak-goal = [italic]Objetivo atual: Invocar Nar'Sie ativando a runa 'Rasgar o Véu' com 9 cultistas, construtos ou fantasmas invocados sobre ela.
    A invocação só pode ser feita na área {$firstLoc}, {$secondLoc} ou {$thirdLoc} - onde o véu está fraco o suficiente para o ritual começar.[/italic]

cult-status-veil-weak-cultdata = Membros do culto atuais: {$cultCount} | Conversões até a Ascensão: {$cultUntilRise}
    Cultistas: {$cultistCount}
    Construtos: {$constructCount}

cult-narsie-sacrifice-accept = "Aceito seu sacrifício."
cult-narsie-target-down = "Sim! Este é o que eu desejo! Você se saiu bem."

cult-ascend-1 = O véu enfraquece conforme seu culto cresce, e seus olhos começam a brilhar...
cult-ascend-2 = O véu enfraquece conforme seu culto cresce, e você não consegue mais esconder sua verdadeira natureza!

cult-deconverted = Você de repente se desconvérte e não se considera mais um cultista!

cult-commune-window = Comunhão
cult-commune-info = Sussurre através do véu e comunique-se com seus companheiros adoradores.
cult-commune-send = Enviar
cult-commune-message = Acólito {$name} (como {$job}): {$message}
cult-commune-incantation = Y'll tor tz'ul z'nik rar.

cult-narsie-spawning = A realidade se desfaz ao seu redor...

cult-win-announcement-shuttle-call = Devido a complicações espaço-temporais, a estação foi considerada inviável para resgate. Uma nave de transferência de tripulação foi despachada. Falha em embarcar e retornar ao Comando Central para debriefing será interpretada como abandono de contrato, e suas famílias sofrerão penalidades até que os custos sejam compensados.
    ETA: {$time} {$units}.
cult-win-announcement = Devido a complicações espaço-temporais, a estação foi considerada inviável para resgate. Falha em retornar ao Comando Central para debriefing será interpretada como abandono de contrato, e suas famílias sofrerão penalidades até que os custos sejam compensados.

cult-ghost-role-name = Cultista do Sangue Reacordado
cult-ghost-role-desc = Um Cultista do Sangue fervoroso de Nar'Sie, reacordado após catatonia.
cult-ghost-role-rules = Você é um antagonista em equipe. Trabalhe com seus companheiros Cultistas para cumprir seus objetivos.
                        Sacrifique os membros da tripulação que sua divindade deseja e rasgue o véu que a aprisiona.

cult-roundend-victory = O culto do sangue invocou Nar'Sie e reivindicou
    o setor em nome dele.
cult-roundend-failure = O culto do sangue não conseguiu invocar seu mestre.
cult-roundend-count = Havia {$count} cultistas do sangue no total.
cult-roundend-sacrifices = O culto do sangue ofereceu {$sacrifices} almas à Geômetra do Sangue.
